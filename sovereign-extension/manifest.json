{
  "manifest_version": 3,
  "name": "Sovereign Trading Bridge",
  "version": "1.0",
  "description": "Voice-activated trading bridge for Sovereign Analyst.",
  "permissions": [
    "storage"
  ],
  "host_permissions": [],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["styles.css"]
    }
  ],
  "action": {
    "default_popup": "popup.html"
  }
}
